# ==========================================================================
# Sessualmente — variabili d'ambiente
# Copia questo file in `.env.local` e compila i valori per lo sviluppo locale.
# Valori di produzione vanno configurati su Vercel (project > settings > env).
# ==========================================================================

# --- Applicazione -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# "development" | "staging" | "production" — controlla robots, analytics, ecc.
NEXT_PUBLIC_SITE_ENV=development

# --- Supabase (region EU Frankfurt) ----------------------------------------
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: solo lato server, mai esposta al client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Italia) -------------------------------------------------------
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_FIRST_SESSION=

# --- Resend (email transazionali) ------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@sessualmente.it
RESEND_REPLY_TO=support@sessualmente.it

# --- Cal.com ---------------------------------------------------------------
# Webhook che conferma bookings e arricchisce con meet_url.
CAL_WEBHOOK_SECRET=
NEXT_PUBLIC_CAL_NAMESPACE=sessualmente

# --- Sentry ----------------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- PostHog (EU) ----------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
